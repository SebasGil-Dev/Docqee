# Monorepo: Docqee
# Keep local environment files out of Git, but allow examples.
**/.env
**/.env.*
!**/.env.example
!**/.env*.example

# Dependencies and package managers
**/node_modules/

# Build outputs
**/dist/
**/coverage/
**/*.tsbuildinfo
Front/vite.config.js
Front/vite.config.d.ts

# Runtime storage and local artifacts
Back/storage/uploads/
Back/storage/tmp/
Front/temp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/

# Playwright — archivos generados en ejecucion (no subir)
Front/playwright-report/
Front/test-results/
Front/e2e/fixtures/sesion-paciente.json
Front/e2e/fixtures/sesion-estudiante.json

# Claude config local
.claude/