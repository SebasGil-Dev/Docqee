generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cita {
  id_cita                Int                   @id @default(autoincrement())
  id_solicitud           Int
  id_docente_universidad Int
  id_sede                Int
  id_tipo_cita           Int
  cancelada_por_cuenta   Int?
  fecha_hora_inicio      DateTime              @db.Timestamptz(6)
  fecha_hora_fin         DateTime              @db.Timestamptz(6)
  informacion_adicional  String?
  estado                 cita_estado_enum      @default(PROPUESTA)
  respondida_at          DateTime?             @db.Timestamptz(6)
  motivo_cancelacion     String?
  finalizada_at          DateTime?             @db.Timestamptz(6)
  recordatorio_24h_enviado Boolean             @default(false)
  fecha_creacion         DateTime              @default(now()) @db.Timestamptz(6)
  fecha_actualizacion    DateTime              @default(now()) @db.Timestamptz(6)
  cuenta_acceso          cuenta_acceso?        @relation(fields: [cancelada_por_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_cita_cancelada_por")
  docente_universidad    docente_universidad   @relation(fields: [id_docente_universidad], references: [id_docente_universidad], onDelete: NoAction, onUpdate: NoAction, map: "fk_cita_docente_universidad")
  sede                   sede                  @relation(fields: [id_sede], references: [id_sede], onDelete: NoAction, onUpdate: NoAction, map: "fk_cita_sede")
  solicitud              solicitud             @relation(fields: [id_solicitud], references: [id_solicitud], onDelete: NoAction, onUpdate: NoAction, map: "fk_cita_solicitud")
  tipo_cita              tipo_cita             @relation(fields: [id_tipo_cita], references: [id_tipo_cita], onDelete: NoAction, onUpdate: NoAction, map: "fk_cita_tipo_cita")
  cita_tratamiento       cita_tratamiento[]
  reprogramacion_cita    reprogramacion_cita[]
  valoracion             valoracion[]
}

model cita_tratamiento {
  id_cita             Int
  id_tipo_tratamiento Int
  cita                cita             @relation(fields: [id_cita], references: [id_cita], onDelete: NoAction, onUpdate: NoAction, map: "fk_cita_tratamiento_cita")
  tipo_tratamiento    tipo_tratamiento @relation(fields: [id_tipo_tratamiento], references: [id_tipo_tratamiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_cita_tratamiento_tipo")

  @@id([id_cita, id_tipo_tratamiento], map: "pk_cita_tratamiento")
}

model ciudad {
  id_ciudad Int         @id @default(autoincrement())
  nombre    String      @unique(map: "uq_ciudad_nombre") @db.VarChar(120)
  localidad localidad[]
}

model conversacion {
  id_conversacion Int                      @id @default(autoincrement())
  id_solicitud    Int                      @unique(map: "uq_conversacion_solicitud")
  estado          conversacion_estado_enum @default(ACTIVA)
  habilitada_at   DateTime                 @default(now()) @db.Timestamptz(6)
  solo_lectura_at DateTime?                @db.Timestamptz(6)
  fecha_creacion  DateTime                 @default(now()) @db.Timestamptz(6)
  solicitud       solicitud                @relation(fields: [id_solicitud], references: [id_solicitud], onDelete: NoAction, onUpdate: NoAction, map: "fk_conversacion_solicitud")
  mensaje         mensaje[]
}

model credencial_inicial {
  id_credencial_inicial Int                @id @default(autoincrement())
  id_cuenta_acceso      Int                @unique(map: "uq_credencial_inicial_cuenta")
  anulada_at            DateTime?          @db.Timestamptz(6)
  fecha_creacion        DateTime           @default(now()) @db.Timestamptz(6)
  cuenta_acceso         cuenta_acceso      @relation(fields: [id_cuenta_acceso], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_credencial_inicial_cuenta")
  envio_credencial      envio_credencial[]
}

model cuenta_acceso {
  id_cuenta                                                                   Int                       @id @default(autoincrement())
  tipo_cuenta                                                                 tipo_cuenta_enum
  correo                                                                      String                    @unique(map: "uq_cuenta_acceso_correo") @db.Citext
  password_hash                                                               String
  estado                                                                      estado_simple_enum        @default(ACTIVO)
  correo_verificado                                                           Boolean                   @default(false)
  correo_verificado_at                                                        DateTime?                 @db.Timestamptz(6)
  primer_ingreso_pendiente                                                    Boolean                   @default(true)
  ultimo_login_at                                                             DateTime?                 @db.Timestamptz(6)
  fecha_creacion                                                              DateTime                  @default(now()) @db.Timestamptz(6)
  fecha_actualizacion                                                         DateTime                  @default(now()) @db.Timestamptz(6)
  cita                                                                        cita[]
  credencial_inicial                                                          credencial_inicial?
  cuenta_admin_plataforma                                                     cuenta_admin_plataforma?
  cuenta_admin_universidad                                                    cuenta_admin_universidad?
  cuenta_estudiante                                                           cuenta_estudiante?
  cuenta_paciente                                                             cuenta_paciente?
  mensaje                                                                     mensaje[]
  notificacion                                                                notificacion[]
  recuperacion_cuenta                                                         recuperacion_cuenta[]
  reprogramacion_cita_reprogramacion_cita_propuesta_por_cuentaTocuenta_acceso reprogramacion_cita[]     @relation("reprogramacion_cita_propuesta_por_cuentaTocuenta_acceso")
  reprogramacion_cita_reprogramacion_cita_respuesta_por_cuentaTocuenta_acceso reprogramacion_cita[]     @relation("reprogramacion_cita_respuesta_por_cuentaTocuenta_acceso")
  solicitud                                                                   solicitud[]
  valoracion_valoracion_id_cuenta_emisorTocuenta_acceso                       valoracion[]              @relation("valoracion_id_cuenta_emisorTocuenta_acceso")
  valoracion_valoracion_id_cuenta_receptorTocuenta_acceso                     valoracion[]              @relation("valoracion_id_cuenta_receptorTocuenta_acceso")
  verificacion_correo                                                         verificacion_correo[]
}

model cuenta_admin_plataforma {
  id_cuenta           Int           @id
  nombres             String        @db.VarChar(120)
  apellidos           String        @db.VarChar(120)
  fecha_creacion      DateTime      @default(now()) @db.Timestamptz(6)
  fecha_actualizacion DateTime      @default(now()) @db.Timestamptz(6)
  cuenta_acceso       cuenta_acceso @relation(fields: [id_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_admin_plataforma_cuenta")
}

model cuenta_admin_universidad {
  id_cuenta           Int           @id
  id_universidad      Int           @unique(map: "uq_admin_universidad_universidad")
  nombres             String        @db.VarChar(120)
  apellidos           String        @db.VarChar(120)
  celular             String?       @db.VarChar(30)
  fecha_creacion      DateTime      @default(now()) @db.Timestamptz(6)
  fecha_actualizacion DateTime      @default(now()) @db.Timestamptz(6)
  cuenta_acceso       cuenta_acceso @relation(fields: [id_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_admin_universidad_cuenta")
  universidad         universidad   @relation(fields: [id_universidad], references: [id_universidad], onDelete: NoAction, onUpdate: NoAction, map: "fk_admin_universidad_universidad")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cuenta_estudiante {
  id_cuenta                Int                        @id
  id_persona               Int                        @unique(map: "uq_cuenta_estudiante_persona")
  id_universidad           Int
  celular                  String                     @db.VarChar(30)
  semestre                 Int                        @db.SmallInt
  fecha_creacion           DateTime                   @default(now()) @db.Timestamptz(6)
  fecha_actualizacion      DateTime                   @default(now()) @db.Timestamptz(6)
  cuenta_acceso            cuenta_acceso              @relation(fields: [id_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_estudiante_cuenta")
  persona                  persona                    @relation(fields: [id_persona], references: [id_persona], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_estudiante_persona")
  universidad              universidad                @relation(fields: [id_universidad], references: [id_universidad], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_estudiante_universidad")
  enlace_profesional       enlace_profesional[]
  estudiante_sede_practica estudiante_sede_practica[]
  estudiante_tratamiento   estudiante_tratamiento[]
  horario_bloqueado        horario_bloqueado[]
  perfil_estudiante        perfil_estudiante?
  solicitud                solicitud[]

  @@index([id_universidad, fecha_creacion], map: "idx_cuenta_estudiante_universidad_fecha")
  @@index([fecha_creacion], map: "idx_cuenta_estudiante_fecha")
}

model cuenta_paciente {
  id_cuenta            Int                @id
  id_persona           Int                @unique(map: "uq_cuenta_paciente_persona")
  id_localidad         Int
  id_tutor_responsable Int?
  sexo                 sexo_enum
  fecha_nacimiento     DateTime           @db.Date
  celular              String             @db.VarChar(30)
  foto_url             String?
  fecha_creacion       DateTime           @default(now()) @db.Timestamptz(6)
  fecha_actualizacion  DateTime           @default(now()) @db.Timestamptz(6)
  cuenta_acceso        cuenta_acceso      @relation(fields: [id_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_paciente_cuenta")
  localidad            localidad          @relation(fields: [id_localidad], references: [id_localidad], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_paciente_localidad")
  persona              persona            @relation(fields: [id_persona], references: [id_persona], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_paciente_persona")
  tutor_responsable    tutor_responsable? @relation(fields: [id_tutor_responsable], references: [id_tutor_responsable], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_paciente_tutor")
  solicitud            solicitud[]
}

model docente {
  id_docente          Int                   @id @default(autoincrement())
  id_tipo_documento   Int                   @db.SmallInt
  numero_documento    String                @db.VarChar(30)
  nombres             String                @db.VarChar(120)
  apellidos           String                @db.VarChar(120)
  fecha_creacion      DateTime              @default(now()) @db.Timestamptz(6)
  fecha_actualizacion DateTime              @default(now()) @db.Timestamptz(6)
  tipo_documento      tipo_documento        @relation(fields: [id_tipo_documento], references: [id_tipo_documento], onDelete: NoAction, onUpdate: NoAction, map: "fk_docente_tipo_documento")
  docente_universidad docente_universidad[]

  @@unique([id_tipo_documento, numero_documento], map: "uq_docente_documento")
}

model docente_universidad {
  id_docente_universidad Int                @id @default(autoincrement())
  id_docente             Int
  id_universidad         Int
  estado                 estado_simple_enum @default(ACTIVO)
  fecha_creacion         DateTime           @default(now()) @db.Timestamptz(6)
  fecha_actualizacion    DateTime           @default(now()) @db.Timestamptz(6)
  cita                   cita[]
  reprogramacion_cita_nuevo_docente reprogramacion_cita[] @relation("reprogramacion_cita_nuevo_docente")
  docente                docente            @relation(fields: [id_docente], references: [id_docente], onDelete: NoAction, onUpdate: NoAction, map: "fk_docente_universidad_docente")
  universidad            universidad        @relation(fields: [id_universidad], references: [id_universidad], onDelete: NoAction, onUpdate: NoAction, map: "fk_docente_universidad_universidad")

  @@unique([id_docente, id_universidad], map: "uq_docente_universidad")
}

model enlace_profesional {
  id_enlace_profesional Int               @id @default(autoincrement())
  id_cuenta_estudiante  Int
  tipo_enlace           tipo_enlace_enum
  url                   String
  fecha_creacion        DateTime          @default(now()) @db.Timestamptz(6)
  fecha_actualizacion   DateTime          @default(now()) @db.Timestamptz(6)
  cuenta_estudiante     cuenta_estudiante @relation(fields: [id_cuenta_estudiante], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_enlace_profesional_cuenta")
}

model envio_credencial {
  id_envio_credencial   Int                        @id @default(autoincrement())
  id_credencial_inicial Int
  tipo_envio            tipo_envio_credencial_enum
  enviado_at            DateTime                   @default(now()) @db.Timestamptz(6)
  credencial_inicial    credencial_inicial         @relation(fields: [id_credencial_inicial], references: [id_credencial_inicial], onDelete: NoAction, onUpdate: NoAction, map: "fk_envio_credencial")
}

model estudiante_sede_practica {
  id_estudiante_sede_practica Int                @id @default(autoincrement())
  id_cuenta_estudiante        Int
  id_sede                     Int
  estado                      estado_simple_enum @default(ACTIVO)
  fecha_creacion              DateTime           @default(now()) @db.Timestamptz(6)
  fecha_actualizacion         DateTime           @default(now()) @db.Timestamptz(6)
  cuenta_estudiante           cuenta_estudiante  @relation(fields: [id_cuenta_estudiante], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_estudiante_sede_cuenta")
  sede                        sede               @relation(fields: [id_sede], references: [id_sede], onDelete: NoAction, onUpdate: NoAction, map: "fk_estudiante_sede_sede")

  @@unique([id_cuenta_estudiante, id_sede], map: "uq_estudiante_sede")
  @@index([estado, id_cuenta_estudiante], map: "idx_estudiante_sede_estado_estudiante")
  @@index([id_sede, estado, id_cuenta_estudiante], map: "idx_estudiante_sede_sede_estado_estudiante")
}

model estudiante_tratamiento {
  id_estudiante_tratamiento Int                @id @default(autoincrement())
  id_cuenta_estudiante      Int
  id_tipo_tratamiento       Int
  estado                    estado_simple_enum @default(ACTIVO)
  fecha_creacion            DateTime           @default(now()) @db.Timestamptz(6)
  fecha_actualizacion       DateTime           @default(now()) @db.Timestamptz(6)
  cuenta_estudiante         cuenta_estudiante  @relation(fields: [id_cuenta_estudiante], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_estudiante_tratamiento_cuenta")
  tipo_tratamiento          tipo_tratamiento   @relation(fields: [id_tipo_tratamiento], references: [id_tipo_tratamiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_estudiante_tratamiento_tipo")

  @@unique([id_cuenta_estudiante, id_tipo_tratamiento], map: "uq_estudiante_tratamiento")
  @@index([estado, id_cuenta_estudiante], map: "idx_estudiante_tratamiento_estado_estudiante")
  @@index([id_tipo_tratamiento, estado, id_cuenta_estudiante], map: "idx_estudiante_tratamiento_tipo_estado_estudiante")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
