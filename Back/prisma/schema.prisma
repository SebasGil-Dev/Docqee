}

model perfil_estudiante {
  id_perfil_estudiante   Int               @id @default(autoincrement())
  id_cuenta_estudiante   Int               @unique(map: "uq_perfil_estudiante_cuenta")
  foto_url               String?
  descripcion            String?
  disponibilidad_general String?
  fecha_creacion         DateTime          @default(now()) @db.Timestamptz(6)
