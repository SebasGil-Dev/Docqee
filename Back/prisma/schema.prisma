model solicitud {
  id_solicitud         Int                   @id @default(autoincrement())
  id_cuenta_paciente   Int
  id_cuenta_estudiante Int
  cerrada_por_cuenta   Int?
  motivo_consulta      String?
  estado               solicitud_estado_enum @default(PENDIENTE)
  fecha_envio          DateTime              @default(now()) @db.Timestamptz(6)
  fecha_respuesta      DateTime?             @db.Timestamptz(6)
  fecha_cierre         DateTime?             @db.Timestamptz(6)
  fecha_creacion       DateTime              @default(now()) @db.Timestamptz(6)
  fecha_actualizacion  DateTime              @default(now()) @db.Timestamptz(6)
  cita                 cita[]
  conversacion         conversacion?
  cuenta_acceso        cuenta_acceso?        @relation(fields: [cerrada_por_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_solicitud_cerrada_por")
  cuenta_estudiante    cuenta_estudiante     @relation(fields: [id_cuenta_estudiante], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_solicitud_estudiante")
  cuenta_paciente      cuenta_paciente       @relation(fields: [id_cuenta_paciente], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_solicitud_paciente")
}

model tipo_cita {
  id_tipo_cita Int    @id @default(autoincrement())
  nombre       String @unique(map: "uq_tipo_cita_nombre") @db.VarChar(120)
  cita         cita[]
}

model tipo_documento {
  id_tipo_documento Int                 @id @default(autoincrement()) @db.SmallInt
  codigo            String              @unique(map: "uq_tipo_documento_codigo") @db.VarChar(10)
  nombre            String              @unique(map: "uq_tipo_documento_nombre") @db.VarChar(50)
  docente           docente[]
  persona           persona[]
  tutor_responsable tutor_responsable[]
}

model tipo_tratamiento {
  id_tipo_tratamiento    Int                      @id @default(autoincrement())
  nombre                 String                   @unique(map: "uq_tipo_tratamiento_nombre") @db.VarChar(150)
  descripcion            String?
  cita_tratamiento       cita_tratamiento[]
  estudiante_tratamiento estudiante_tratamiento[]
}

model tutor_responsable {
  id_tutor_responsable Int               @id @default(autoincrement())
  id_tipo_documento    Int               @db.SmallInt
  numero_documento     String            @db.VarChar(30)
  nombres              String            @db.VarChar(120)
  apellidos            String            @db.VarChar(120)
  correo               String            @db.Citext
  celular              String            @db.VarChar(30)
  fecha_creacion       DateTime          @default(now()) @db.Timestamptz(6)
  fecha_actualizacion  DateTime          @default(now()) @db.Timestamptz(6)
  cuenta_paciente      cuenta_paciente[]
  tipo_documento       tipo_documento    @relation(fields: [id_tipo_documento], references: [id_tipo_documento], onDelete: NoAction, onUpdate: NoAction, map: "fk_tutor_tipo_documento")

  @@unique([id_tipo_documento, numero_documento], map: "uq_tutor_documento")
}

model universidad {
  id_universidad           Int                       @id @default(autoincrement())
  id_localidad_principal   Int
  nombre                   String                    @unique(map: "uq_universidad_nombre") @db.VarChar(200)
  logo_url                 String?
  estado                   estado_simple_enum        @default(ACTIVO)
  fecha_creacion           DateTime                  @default(now()) @db.Timestamptz(6)
  fecha_actualizacion      DateTime                  @default(now()) @db.Timestamptz(6)
  cuenta_admin_universidad cuenta_admin_universidad?
  cuenta_estudiante        cuenta_estudiante[]
  docente_universidad      docente_universidad[]
  sede                     sede[]
  localidad                localidad                 @relation(fields: [id_localidad_principal], references: [id_localidad], onDelete: NoAction, onUpdate: NoAction, map: "fk_universidad_localidad")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model valoracion {
  id_valoracion                                              Int           @id @default(autoincrement())
  id_cita                                                    Int
  id_cuenta_emisor                                           Int
  id_cuenta_receptor                                         Int
  calificacion                                               Int           @db.SmallInt
  comentario                                                 String?
  fecha_creacion                                             DateTime      @default(now()) @db.Timestamptz(6)
  cita                                                       cita          @relation(fields: [id_cita], references: [id_cita], onDelete: NoAction, onUpdate: NoAction, map: "fk_valoracion_cita")
  cuenta_acceso_valoracion_id_cuenta_emisorTocuenta_acceso   cuenta_acceso @relation("valoracion_id_cuenta_emisorTocuenta_acceso", fields: [id_cuenta_emisor], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_valoracion_emisor")
  cuenta_acceso_valoracion_id_cuenta_receptorTocuenta_acceso cuenta_acceso @relation("valoracion_id_cuenta_receptorTocuenta_acceso", fields: [id_cuenta_receptor], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_valoracion_receptor")

  @@unique([id_cita, id_cuenta_emisor], map: "uq_valoracion_cita_emisor")
}

model verificacion_correo {
  id_verificacion_correo Int           @id @default(autoincrement())
  id_cuenta_acceso       Int
  codigo_hash            String
  expira_at              DateTime      @db.Timestamptz(6)
  usado_at               DateTime?     @db.Timestamptz(6)
  fecha_creacion         DateTime      @default(now()) @db.Timestamptz(6)
  cuenta_acceso          cuenta_acceso @relation(fields: [id_cuenta_acceso], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_verificacion_correo_cuenta")
}

