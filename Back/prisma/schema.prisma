model localidad {
  id_localidad    Int               @id @default(autoincrement())
  id_ciudad       Int
  nombre          String            @db.VarChar(120)
  cuenta_paciente cuenta_paciente[]
  ciudad          ciudad            @relation(fields: [id_ciudad], references: [id_ciudad], onDelete: NoAction, onUpdate: NoAction, map: "fk_localidad_ciudad")
  sede            sede[]
  universidad     universidad[]

  @@unique([id_ciudad, nombre], map: "uq_localidad_ciudad_nombre")
}

