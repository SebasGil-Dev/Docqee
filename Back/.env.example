# Server
PORT=3000
NODE_ENV=development

# CORS
# Multiple origins separated by commas.
FRONTEND_URL=http://localhost:5173,http://localhost:4173

# Database (Supabase)
# DATABASE_URL: Supabase Transaction Pooler, usually port 6543.
# DIRECT_URL: Direct connection, usually port 5432, used for Prisma migrations.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Platform admins for npm run seed.
# Never commit real credentials. Put real values only in Back/.env or your deployment environment.
PLATFORM_ADMIN_1_EMAIL=admin1@example.com
PLATFORM_ADMIN_1_PASSWORD=change_me
PLATFORM_ADMIN_1_FIRST_NAME=Admin
PLATFORM_ADMIN_1_LAST_NAME=Uno
PLATFORM_ADMIN_2_EMAIL=admin2@example.com
PLATFORM_ADMIN_2_PASSWORD=change_me
PLATFORM_ADMIN_2_FIRST_NAME=Admin
PLATFORM_ADMIN_2_LAST_NAME=Dos

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Brevo)
BREVO_API_KEY=your_brevo_api_key_here
MAIL_FROM=no-reply@docqee.com
INSTITUTIONAL_PARTNERSHIP_EMAIL=example@example.com

# Cloudinary
# Use these three variables or CLOUDINARY_URL. Do not commit real secrets.
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
# CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
