# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Múltiples orígenes separados por coma
FRONTEND_URL=http://localhost:5173,http://localhost:4173

# ─── Base de datos (Supabase) ────────────────────────────────────────────────
# DATABASE_URL  → Transaction Pooler de Supabase (puerto 6543) — úsalo en producción y desarrollo
# DIRECT_URL    → Conexión directa (puerto 5432) — solo se usa para prisma migrate
#
# Encuéntralos en: Supabase Dashboard → Project Settings → Database → Connection string
#
# Formato Transaction Pooler:
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Formato Direct:
#   postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Administrador de plataforma por defecto ─────────────────────────────────
# Se crea automáticamente en el primer login si no existe
PLATFORM_ADMIN_EMAIL=admin@docqee.local
PLATFORM_ADMIN_PASSWORD=Admin123!
PLATFORM_ADMIN_NOMBRES=Admin
PLATFORM_ADMIN_APELLIDOS=Docqee

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Correo (Brevo) ──────────────────────────────────────────────────────────
# Crea tu API key en: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
MAIL_FROM=no-reply@docqee.com
